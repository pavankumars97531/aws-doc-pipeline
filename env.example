AWS_REGION=us-east-1
S3_UPLOAD_BUCKET=your-raw-uploads-bucket-name
S3_RESULTS_BUCKET=your-results-bucket-name
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/doc-pipeline-queue
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_ACCOUNT_ID:doc-pipeline-notifications

# Optional - leave empty to skip database
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_NAME=pipeline_db
DB_USER=pipeline_user
DB_PASSWORD=your-db-password

# Set to true to fetch DB credentials from AWS Secrets Manager instead
USE_SECRETS_MANAGER=false
